# ENGYE — copy to .env.local and fill in. Secrets never get committed.

# Arc testnet ground truth
RPC=                        # personal RPC from `arc-canteen rpc-url` (or https://rpc.testnet.arc.network)
ARC_CHAIN_ID=5042002
USDC_ADDRESS=0x3600000000000000000000000000000000000000
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ENGYE contracts (deployed + verified via ./scripts/deploy.sh — see README)
ESCROW_ADDRESS=
REFUND_VAULT_ADDRESS=
PROVIDER_STAKE_ADDRESS=

# EIP-7702 account model
ROOT_ADDRESS=               # funded root EOA (foundry keystore) — delegates to IthacaAccount
DELEGATE_ADDRESS=           # SessionAccount.vy delegate for the 6 role accounts
ITHACA_IMPL=                # IthacaAccount implementation the root delegates to

# ERC-8004 canonical registries on Arc testnet
ERC8004_IDENTITY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC8004_VALIDATION=0x8004Cb1BF31DAf7788923b405b754f57acEB4272

# LLM (Groq only; per-role models, model-level failover)
GROQ_API_KEY=
BROKER_MODEL=openai/gpt-oss-120b
VALIDATOR_MODEL=openai/gpt-oss-20b
DEMAND_MODEL=openai/gpt-oss-20b
FALLBACK_MODEL=qwen/qwen3-32b

# app
APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# economics (plan constants)
FEE_BPS=200
MIN_BOND=0.001
MAX_BOND=0.25
RISK_MARGIN=1.0
DAILY_DEMAND_BUDGET=2.0

# role wallets — generate with `bun scripts/generate-wallets.mts` (testnet only)
BROKER_ADDRESS=
BROKER_PRIVATE_KEY=
DEMAND_ADDRESS=
DEMAND_PRIVATE_KEY=
PROVIDER1_ADDRESS=
PROVIDER1_PRIVATE_KEY=
PROVIDER2_ADDRESS=
PROVIDER2_PRIVATE_KEY=
PROVIDER3_ADDRESS=
PROVIDER3_PRIVATE_KEY=
VALIDATOR_ADDRESS=
VALIDATOR_PRIVATE_KEY=
SESSION_ADDRESS=
SESSION_PRIVATE_KEY=

# ERC-8004 identity NFTs — filled by `bun scripts/register-agents.ts`
AGENT_ID_ENGYE=
AGENT_ID_PROVIDER1=
AGENT_ID_PROVIDER2=
AGENT_ID_PROVIDER3=
AGENT_ID_VALIDATOR=
